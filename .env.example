# Copy this file to `.env` for local development.
# For Cloudflare deployment, set these as project environment variables /
# secrets (e.g. via `wrangler secret put` or the dashboard). Secrets should
# NOT be committed.

# ── Slack OAuth (Sign in with Slack) ─────────────────────────────────────────
# Create a Slack app at https://api.slack.com/apps
#  - Add the redirect URL <your-origin>/api/auth/callback under OAuth & Permissions
#  - Enable the "identity.basic" user scope
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ── Slack bot token (for posting notifications) ──────────────────────────────
# Bot token (xoxb-...) with the chat:write scope. Invite the bot to the
# channel(s) below.
SLACK_OAUTH=

# ── Google service account ───────────────────────────────────────────────────
# The full service-account JSON, as a single-line string. Share your
# spreadsheet with the service account's client_email (Editor access).
GOOGLE_SERVICE_KEY=

# ── Google Sheets target ─────────────────────────────────────────────────────
# Spreadsheet ID is the long token in the sheet URL:
#   https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
SPREADSHEET_ID=
# Optional: a separate scratch spreadsheet used when not in production.
SPREADSHEET_ID_TEST=

# ── Slack channels ───────────────────────────────────────────────────────────
# Channel IDs (e.g. C0123ABCD), not names.
SLACK_CHANNEL_ID=
# Optional: a separate channel used when not in production.
SLACK_CHANNEL_ID_TEST=

# ── Optional customization (defaults shown) ──────────────────────────────────
# APP_NAME=Sheetbell
# SHEET_TAB_CONVERSATIONS=Conversations
# SHEET_TAB_ELIGIBLE=Eligible
# ELIGIBLE_ENGAGEMENT_COLUMN=Last engagement / who did it
# ELIGIBLE_NOTES_COLUMN=Last Conversation Notes
# MATCH_SIMILARITY_THRESHOLD=0.7
