---

import "../index.css"
import FormPage from "../components/FormPage.astro"
import Navbar from "../components/Navbar.astro"
import { getConfig } from "../lib/config.js"
import { primaryFormWorkflow } from "../workflows/index.js"

const user = Astro.locals.user;
const { appName } = getConfig();
const { title, fields } = primaryFormWorkflow.trigger;

---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="robots" content="noindex, nofollow">
  <link rel="icon" href="/favicon.ico" type="image/x-icon" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Fira+Mono:wght@400;700&display=swap"
  />
</head>
<body class="text-white font-sans p-4 pt-0 pb-0 bg-gray-900">
  <Navbar user={user} appName={appName} />
  <FormPage title={title} fields={fields} />
</body>
</html>

