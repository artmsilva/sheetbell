---
import "../index.css";
import Navbar from "../components/Navbar.astro";
import { getConfig } from "../lib/config.js";
import { allWorkflows } from "../workflows/index.js";

const user = Astro.locals.user;
const { appName } = getConfig();

const TYPE_COLOR = {
  "sheets.append": "bg-green-700",
  "sheets.matchUpdate": "bg-emerald-700",
  "slack.message": "bg-purple-700",
  "http.request": "bg-amber-700",
};
const condition = (step) =>
  step.when ? `when ${step.when}` : step.unless ? `unless ${step.unless}` : null;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Workflows</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="/favicon.ico" type="image/x-icon" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fira+Mono:wght@400;700&display=swap"
    />
  </head>
  <body class="text-white font-mono bg-gray-900 min-h-screen px-4 pt-0 pb-12">
    <Navbar user={user} appName={appName} />
    <main class="max-w-3xl mx-auto">
      <h1 class="text-2xl md:text-3xl font-bold mb-2">Workflows</h1>
      <p class="text-sm text-gray-400 mb-8">
        Each workflow runs its steps top to bottom. Defined in
        <code class="text-gray-300">src/workflows/</code>.
      </p>

      {
        allWorkflows.map((wf) => (
          <section class="mb-10">
            <div class="flex items-center gap-3 mb-1">
              <h2 class="text-xl font-bold">{wf.name}</h2>
              <span class="text-xs px-2 py-0.5 rounded bg-gray-700 text-gray-300">
                trigger: {wf.trigger?.type ?? "—"}
              </span>
            </div>
            <p class="text-xs text-gray-500 mb-4">
              form: <code>/</code> · webhook: <code>/api/hooks/{wf.slug}</code>
            </p>

            <ol class="relative border-l border-gray-700 ml-2 space-y-4">
              {wf.steps.map((step) => (
                <li class="ml-5">
                  <span class="absolute -left-1.5 mt-2 h-3 w-3 rounded-full bg-gray-600" />
                  <div class="flex flex-wrap items-center gap-2">
                    <span class={`text-xs px-2 py-0.5 rounded text-white ${TYPE_COLOR[step.type] ?? "bg-gray-700"}`}>
                      {step.type}
                    </span>
                    <span class="text-sm text-gray-200">{step.id}</span>
                    {step.core && (
                      <span class="text-xs px-1.5 py-0.5 rounded bg-red-900 text-red-200">core</span>
                    )}
                    {condition(step) && (
                      <span class="text-xs text-gray-500">{condition(step)}</span>
                    )}
                  </div>
                </li>
              ))}
            </ol>
          </section>
        ))
      }
    </main>
  </body>
</html>
