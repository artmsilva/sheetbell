---
// Form for a workflow's form trigger. Inputs are rendered from `fields`, so the
// same component serves any form workflow. Interactivity is a single client
// <script> that collects every named field — no UI framework.
const { fields = [], title = "Submit" } = Astro.props;
---

<main
  class="w-full max-w-md md:max-w-2xl lg:max-w-4xl mx-auto p-4 md:p-6 lg:p-8 bg-gray-900 min-h-screen"
>
  <div
    id="form-status"
    role="alert"
    aria-live="assertive"
    hidden
    class="mb-6 md:mb-8 p-3 rounded-md text-white text-center max-w-xl mx-auto transition-opacity duration-300 ease-in-out"
  >
  </div>

  <div
    id="form-celebration"
    hidden
    class="mb-6 md:mb-8 p-4 rounded-md text-white text-center max-w-xl mx-auto bg-linear-to-r from-purple-500 via-pink-500 to-red-500 animate-pulse"
  >
    <h2 class="text-xl font-bold animate-bounce">Submission Successful! 🎉</h2>
    <p>Thank you!</p>
  </div>

  <h1
    id="form-title"
    class="text-2xl md:text-3xl lg:text-4xl font-bold mb-6 md:mb-8 text-white text-center"
  >
    {title}
  </h1>

  <form
    id="convo-form"
    aria-labelledby="form-title"
    class="space-y-6 md:space-y-8 max-w-2xl mx-auto"
  >
    <fieldset class="border border-gray-700 rounded-md p-4 md:p-6">
      <legend class="text-lg font-medium px-2 text-gray-300">Details</legend>

      {
        fields.map((field) => (
          <div class="mb-4">
            <label for={field.name} class="block mb-1 font-medium text-gray-300">
              {field.label}
            </label>
            {field.type === "textarea" ? (
              <textarea
                id={field.name}
                name={field.name}
                rows={field.rows ?? 5}
                required={field.required}
                class="w-full px-3 py-2 border border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-gray-800 text-white disabled:opacity-70"
              />
            ) : (
              <input
                id={field.name}
                name={field.name}
                type={field.type === "date" ? "date" : "text"}
                required={field.required}
                class="w-full px-3 py-2 border border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-gray-800 text-white disabled:opacity-70"
              />
            )}
          </div>
        ))
      }
    </fieldset>

    <button
      id="submit-btn"
      type="submit"
      class="w-full md:w-1/2 lg:w-1/3 mx-auto flex justify-center py-2 md:py-3 px-4 border border-transparent rounded-md shadow-sm text-white cursor-pointer bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 font-medium transition-colors text-lg disabled:bg-blue-400 disabled:cursor-not-allowed"
    >
      Submit
    </button>
  </form>
</main>

<script>
  const form = document.getElementById("convo-form") as HTMLFormElement;
  const statusBox = document.getElementById("form-status") as HTMLElement;
  const celebration = document.getElementById("form-celebration") as HTMLElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;

  // Every named control in the form — works for whatever fields were rendered.
  const controls = () =>
    Array.from(
      form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>("[name]")
    );

  const today = new Date().toISOString().split("T")[0];
  for (const el of controls()) {
    if (el.type === "date" && !el.value) el.value = today;
    // Convenience prefill in local development only.
    if (import.meta.env.DEV && el.type !== "date" && !el.value) {
      el.value = el.tagName === "TEXTAREA" ? `sample - ${new Date().toISOString()}` : "Sample";
    }
  }

  const STATUS_BG = { info: "bg-blue-600", error: "bg-red-600", success: "bg-green-600" } as const;
  function showStatus(kind: keyof typeof STATUS_BG, msg: string) {
    statusBox.textContent = msg;
    statusBox.classList.remove("bg-blue-600", "bg-red-600", "bg-green-600");
    statusBox.classList.add(STATUS_BG[kind]);
    statusBox.hidden = false;
  }
  const hideStatus = () => (statusBox.hidden = true);
  function setSubmitting(on: boolean) {
    submitBtn.disabled = on;
    submitBtn.textContent = on ? "Submitting..." : "Submit";
    for (const el of controls()) el.disabled = on;
  }

  async function celebrate() {
    const { default: confetti } = await import("canvas-confetti");
    celebration.hidden = false;
    const duration = 3000;
    const animationEnd = Date.now() + duration;
    const defaults = { startVelocity: 30, spread: 360, ticks: 60, zIndex: 100 };
    const rand = (min: number, max: number) => Math.random() * (max - min) + min;
    const interval = setInterval(() => {
      const timeLeft = animationEnd - Date.now();
      if (timeLeft <= 0) {
        clearInterval(interval);
        celebration.hidden = true;
        showStatus("success", "Your form was successfully submitted.");
        setTimeout(hideStatus, 1500);
        return;
      }
      const particleCount = 50 * (timeLeft / duration);
      confetti({ ...defaults, particleCount, origin: { x: rand(0.1, 0.3), y: Math.random() - 0.2 } });
      confetti({ ...defaults, particleCount, origin: { x: rand(0.7, 0.9), y: Math.random() - 0.2 } });
    }, 250);
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    setSubmitting(true);
    hideStatus();
    showStatus("info", "Submitting your form...");

    const body = Object.fromEntries(controls().map((el) => [el.name, el.value]));

    try {
      const res = await fetch("/api/submit", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
      });
      if (!res.ok) throw new Error("Server responded with an error");
      hideStatus();
      form.reset();
      for (const el of controls()) if (el.type === "date") el.value = today;
      celebrate();
    } catch (err) {
      console.error(err);
      showStatus("error", "There was an error submitting the form. Please try again.");
    } finally {
      setSubmitting(false);
    }
  });
</script>
