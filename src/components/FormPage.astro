---
// Conversation form. Static markup rendered by Astro; the interactive behavior
// (submit, status messages, confetti celebration) lives in the client script
// below — no UI framework needed.
---

<main
  class="w-full max-w-md md:max-w-2xl lg:max-w-4xl mx-auto p-4 md:p-6 lg:p-8 bg-gray-900 min-h-screen"
>
  <div
    id="form-status"
    role="alert"
    aria-live="assertive"
    hidden
    class="mb-6 md:mb-8 p-3 rounded-md text-white text-center max-w-xl mx-auto transition-opacity duration-300 ease-in-out"
  >
  </div>

  <div
    id="form-celebration"
    hidden
    class="mb-6 md:mb-8 p-4 rounded-md text-white text-center max-w-xl mx-auto bg-linear-to-r from-purple-500 via-pink-500 to-red-500 animate-pulse"
  >
    <h2 class="text-xl font-bold animate-bounce">Submission Successful! 🎉</h2>
    <p>Thank you for recording your conversation!</p>
  </div>

  <h1
    id="form-title"
    class="text-2xl md:text-3xl lg:text-4xl font-bold mb-6 md:mb-8 text-white text-center"
  >
    Record a conversation
  </h1>

  <form
    id="convo-form"
    aria-labelledby="form-title"
    class="space-y-6 md:space-y-8 max-w-2xl mx-auto"
  >
    <fieldset class="border border-gray-700 rounded-md p-4 md:p-6">
      <legend class="text-lg font-medium px-2 text-gray-300">
        Conversation details
      </legend>

      <div class="grid md:grid-cols-2 gap-4 md:gap-6 mb-4">
        <div class="mb-4 md:mb-0">
          <label for="contact" class="block mb-1 font-medium text-gray-300">
            Who was the conversation with?
          </label>
          <input
            required
            type="text"
            id="contact"
            name="contact"
            class="w-full px-3 py-2 border border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-gray-800 text-white disabled:opacity-70"
          />
        </div>

        <div class="mb-4 md:mb-0">
          <label for="organizer" class="block mb-1 font-medium text-gray-300">
            Who led the conversation?
          </label>
          <input
            required
            type="text"
            id="organizer"
            name="organizer"
            class="w-full px-3 py-2 border border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-gray-800 text-white disabled:opacity-70"
          />
        </div>
      </div>

      <div class="mb-4">
        <label for="date" class="block mb-1 font-medium text-gray-300">
          When did this conversation take place?
        </label>
        <input
          required
          type="date"
          id="date"
          name="date"
          class="w-full px-3 py-2 border border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-gray-800 text-white disabled:opacity-70"
        />
      </div>

      <div>
        <label for="message" class="block mb-1 font-medium text-gray-300">
          How did the conversation go?
        </label>
        <textarea
          required
          id="message"
          name="message"
          rows="10"
          class="w-full px-3 py-2 border border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-gray-800 text-white disabled:opacity-70"
        ></textarea>
      </div>
    </fieldset>

    <button
      id="submit-btn"
      type="submit"
      class="w-full md:w-1/2 lg:w-1/3 mx-auto flex justify-center py-2 md:py-3 px-4 border border-transparent rounded-md shadow-sm text-white cursor-pointer bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 font-medium transition-colors text-lg disabled:bg-blue-400 disabled:cursor-not-allowed"
    >
      Submit
    </button>
  </form>
</main>

<script>
  // canvas-confetti is loaded on demand (Import on Interaction) — it only fires
  // after a successful submit, so it stays out of the initial bundle.
  const form = document.getElementById("convo-form") as HTMLFormElement;
  const statusBox = document.getElementById("form-status") as HTMLElement;
  const celebration = document.getElementById("form-celebration") as HTMLElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const dateInput = document.getElementById("date") as HTMLInputElement;
  const fieldIds = ["contact", "organizer", "date", "message"] as const;

  const today = new Date().toISOString().split("T")[0];
  if (!dateInput.value) dateInput.value = today;

  // Convenience prefill during local development only.
  if (import.meta.env.DEV) {
    const set = (id: string, v: string) => {
      const el = document.getElementById(id) as HTMLInputElement | null;
      if (el && !el.value) el.value = v;
    };
    set("contact", "John Doe");
    set("organizer", "Jane Doe");
    set("message", `sample - ${new Date().toISOString()}`);
  }

  const STATUS_BG = {
    info: "bg-blue-600",
    error: "bg-red-600",
    success: "bg-green-600",
  } as const;

  function showStatus(kind: keyof typeof STATUS_BG, msg: string) {
    statusBox.textContent = msg;
    statusBox.classList.remove("bg-blue-600", "bg-red-600", "bg-green-600");
    statusBox.classList.add(STATUS_BG[kind]);
    statusBox.hidden = false;
  }
  function hideStatus() {
    statusBox.hidden = true;
  }
  function setSubmitting(on: boolean) {
    submitBtn.disabled = on;
    submitBtn.textContent = on ? "Submitting..." : "Submit";
    for (const id of fieldIds) {
      (document.getElementById(id) as HTMLInputElement).disabled = on;
    }
  }

  async function celebrate() {
    const { default: confetti } = await import("canvas-confetti");
    celebration.hidden = false;
    const duration = 3000;
    const animationEnd = Date.now() + duration;
    const defaults = { startVelocity: 30, spread: 360, ticks: 60, zIndex: 100 };
    const rand = (min: number, max: number) => Math.random() * (max - min) + min;
    const interval = setInterval(() => {
      const timeLeft = animationEnd - Date.now();
      if (timeLeft <= 0) {
        clearInterval(interval);
        celebration.hidden = true;
        showStatus("success", "Your form was successfully submitted.");
        setTimeout(hideStatus, 1500);
        return;
      }
      const particleCount = 50 * (timeLeft / duration);
      confetti({ ...defaults, particleCount, origin: { x: rand(0.1, 0.3), y: Math.random() - 0.2 } });
      confetti({ ...defaults, particleCount, origin: { x: rand(0.7, 0.9), y: Math.random() - 0.2 } });
    }, 250);
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    setSubmitting(true);
    hideStatus();
    showStatus("info", "Submitting your form...");

    const body = Object.fromEntries(
      fieldIds.map((id) => [id, (document.getElementById(id) as HTMLInputElement).value])
    );

    try {
      const res = await fetch("/api/submit", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
      });
      if (!res.ok) throw new Error("Server responded with an error");
      hideStatus();
      form.reset();
      dateInput.value = today;
      celebrate();
    } catch (err) {
      console.error(err);
      showStatus("error", "There was an error submitting the form. Please try again.");
    } finally {
      setSubmitting(false);
    }
  });
</script>
