---
const { user, appName = "Sheetbell" } = Astro.props;
---

<nav class="w-full flex items-center py-4 mb-0">
  <a
    href="/"
    class="font-mono text-lg font-bold text-white hover:text-blue-400 transition-colors"
  >
    {appName}
  </a>
  <a
    href="/docs"
    class="ml-4 text-sm text-gray-400 hover:text-blue-400 font-mono transition-colors"
  >
    Docs
  </a>
  {
    user && (
      <Fragment>
        <span class="ml-auto text-sm text-gray-400 font-mono">{user.name}</span>
        <span class="mx-2 text-gray-600">·</span>
        <a
          href="/api/auth/logout"
          class="text-sm px-3 py-1 rounded bg-gray-700 hover:bg-gray-600 text-gray-300 hover:text-white font-mono transition-colors"
        >
          Log out
        </a>
      </Fragment>
    )
  }
</nav>
